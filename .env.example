# Copy this file to .env and fill in your values.
# The .env file is gitignored.

# Database
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/caseai

# OpenAI (required for Steps 3+; Step 1 does not use it)
OPENAI_API_KEY=sk-replace-me
MODEL_PRIMARY=gpt-4.1
MODEL_CHEAP=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# Debug / dev
DEBUG=false

# MinIO — canonical blob storage for uploaded documents
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Backend reaches MinIO over the compose network:
MINIO_INTERNAL_ENDPOINT=minio:9000
# Browsers reach it through the host port mapping; this hostname
# is embedded into presigned-download URLs, so it must be the URL
# the USER's browser will actually hit.
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET=documents
MINIO_SECURE=false
